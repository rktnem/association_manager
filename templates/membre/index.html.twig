{% extends 'base.html.twig' %}

{% block title %}Membre{% endblock %}

{% block nav_item %}
    <a href="#" class="link item">Membre</a>
    <a href="#" class="link item">Suggestion</a>
{% endblock %}

{% block body %}
    <div class="member-section member-action" {{ stimulus_controller("member/member") }}>
        <section class="list">
            <div class="member-count">
                <div class="header">
                    <span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                            <path fill="none" stroke="currentColor" stroke-linecap="square" stroke-width="3" d="M16 20v-1a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v1M12.5 7a4 4 0 1 1-8 0a4 4 0 0 1 8 0Zm3 4a4 4 0 0 0 0-8M23 20v-1a4 4 0 0 0-4-4"/>
                        </svg>
                    </span>
                    <h3>Membre</h3>
                </div>
                <div>
                    <span>30</span>
                    <span>femmes</span>
                </div>
            </div>
            <div class="member-list">
                <div class="header">
                    <h3>Liste</h3>
                    <div class="header-action">
                        <div class="search">
                            <div class="search-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                    <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21l-4.343-4.343m0 0A8 8 0 1 0 5.343 5.343a8 8 0 0 0 11.314 11.314"/>
                                </svg>
                            </div>
                            <input type="text" name="search" id="search" placeholder="nom du membre...">
                        </div>
                        <div class="operation-btn" {{ stimulus_action("member/member", "display", "click") }}>
                            {% block operation_icon %}{% endblock %}
                        </div>
                    </div>
                </div>
                <div class="content">
                    <table>
                        <thead>
                            <tr>
                                <th>Nom</th>
                                <th>Prénom</th>
                                <th>Adresse</th>
                                <th>Rôle</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for member in members %}
                                <tr>
                                    <td>{{ member.nom }}</td>
                                    <td>{{ member.prenom }}</td>
                                    <td>{{ member.adresse }}</td>
                                    <td>{{ member.role }}</td>
                                    <td>
                                        <a href={{ path("member.edit", { id: member.id}) }} class="link edit-act">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                                <path fill="currentColor" d="M5 19h1.425L16.2 9.225L14.775 7.8L5 17.575zm-2 2v-4.25L16.2 3.575q.3-.275.663-.425t.762-.15t.775.15t.65.45L20.425 5q.3.275.438.65T21 6.4q0 .4-.137.763t-.438.662L7.25 21zM19 6.4L17.6 5zm-3.525 2.125l-.7-.725L16.2 9.225z"/>
                                            </svg>
                                        </a>
                                        <a href="#" class="link delete-act">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                                                <path fill="currentColor" d="M7 21q-.825 0-1.412-.587T5 19V6H4V4h5V3h6v1h5v2h-1v13q0 .825-.587 1.413T17 21zM17 6H7v13h10zM9 17h2V8H9zm4 0h2V8h-2zM7 6v13z"/>
                                            </svg>
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>
        <section class="action" {{ stimulus_target("member/member", "addLayout") }}>
            {% block member_form %}{% endblock %}
        </section>
    </div>
{% endblock %}
